<Page
    x:Class="WinUITemplate.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="24,16,24,24"
                    Spacing="8"
                    HorizontalAlignment="Stretch">

            <!-- 表示設定 -->
            <TextBlock Text="表示設定"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,4"/>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <!-- テーマ選択 -->
                    <Grid Padding="16" MinHeight="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="アプリのテーマ" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="ライト・ダーク・システムに合わせるを選択できます"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <ComboBox x:Name="ThemeComboBox"
                                  Grid.Column="1"
                                  Width="200"
                                  VerticalAlignment="Center"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Tag="System" Content="システムに合わせる"/>
                            <ComboBoxItem Tag="Light" Content="ライト"/>
                            <ComboBoxItem Tag="Dark" Content="ダーク"/>
                        </ComboBox>
                    </Grid>

                    <MenuFlyoutSeparator/>

                    <!-- ウィンドウ不透明度 -->
                    <Grid Padding="16" MinHeight="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="背景の透明度" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="ウィンドウの背景透明度を調整します"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <Slider x:Name="OpacitySlider"
                                Grid.Column="1"
                                Minimum="50" Maximum="100"
                                TickFrequency="5"
                                VerticalAlignment="Center"
                                ValueChanged="OpacitySlider_ValueChanged"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 起動・常駐設定 -->
            <TextBlock Text="起動・常駐設定"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,4"/>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <!-- 自動起動 -->
                    <Grid Padding="16" MinHeight="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Windows 起動時に自動起動" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="サインイン時にアプリを自動的に起動します"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoStartToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Margin="0"
                                      Toggled="AutoStartToggle_Toggled"/>
                    </Grid>

                    <MenuFlyoutSeparator/>

                    <!-- タスクトレイ常駐 -->
                    <Grid Padding="16" MinHeight="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="タスクトレイに常駐" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="タスクトレイにアイコンを表示します"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="TrayIconToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Margin="0"
                                      Toggled="TrayIconToggle_Toggled"/>
                    </Grid>

                    <MenuFlyoutSeparator/>

                    <!-- 閉じるボタンでトレイに最小化 -->
                    <Grid Padding="16" MinHeight="64">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="閉じるボタンでトレイに最小化" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="×ボタンでアプリを終了せずトレイに格納します"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="MinimizeToTrayToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Margin="0"
                                      IsEnabled="{x:Bind TrayIconToggle.IsOn, Mode=OneWay}"
                                      Toggled="MinimizeToTrayToggle_Toggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- アプリ情報 -->
            <TextBlock Text="アプリ情報"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,16,0,4"/>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid Padding="16" MinHeight="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="WinUI Template App" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock x:Name="VersionText"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                    </StackPanel>
                    <HyperlinkButton Grid.Column="1" Content="GitHub" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
