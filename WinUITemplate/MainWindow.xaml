<Window
    x:Class="WinUITemplate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinUI Template App">

    <Grid>
        <!-- カスタムタイトルバー -->
        <Grid x:Name="AppTitleBar"
              Height="48"
              VerticalAlignment="Top"
              Canvas.ZIndex="1">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <Image Source="Assets/AppIcon.png"
                       Width="16" Height="16"
                       VerticalAlignment="Center"/>
                <TextBlock Text="WinUI Template App"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView"
                        PaneDisplayMode="Auto"
                        IsSettingsVisible="True"
                        CompactModeThresholdWidth="640"
                        ExpandedModeThresholdWidth="860"
                        OpenPaneLength="260"
                        IsTitleBarAutoPaddingEnabled="False"
                        SelectionChanged="NavView_SelectionChanged"
                        Loaded="NavView_Loaded"
                        SizeChanged="NavView_SizeChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="home" Content="ホーム">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneHeader>
                <Grid Height="48"/>
            </NavigationView.PaneHeader>

            <!--
                NavigationView の Header は内部テンプレートで左に約24pxのMarginが自動付与される。
                ネガティブマージンで打ち消し、コンテンツのPadding(24px)と揃える。
            -->
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}"
                               Margin="-34,4,0,0"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <Frame x:Name="ContentFrame"
                   IsNavigationStackEnabled="True"
                   Padding="0,8,0,0"/>
        </NavigationView>
    </Grid>
</Window>
