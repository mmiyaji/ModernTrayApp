<Page
    x:Class="WinUITemplate.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent"
    SizeChanged="Page_SizeChanged">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <StackPanel Padding="24,16,24,24" Spacing="16">

                <!-- ページ説明文（ヘッダーは NavigationView 側の "ホーム" で済んでいるので省く） -->
                <TextBlock Text="ここにアプリのメインコンテンツを配置してください。"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- カードグリッド -->
                <Grid x:Name="CardGrid" HorizontalAlignment="Stretch"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
