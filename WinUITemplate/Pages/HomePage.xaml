<Page
    x:Class="WinUITemplate.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="16">
            <TextBlock Text="ようこそ"
                       Style="{StaticResource HeaderTextBlockStyle}"/>
            <TextBlock Text="ここにアプリのメインコンテンツを配置してください。"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- サンプルカード -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Padding="16" Spacing="8">
                        <FontIcon FontSize="32" Glyph="&#xE710;"/>
                        <TextBlock Text="機能 A" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="説明テキスト" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Padding="16" Spacing="8">
                        <FontIcon FontSize="32" Glyph="&#xE8A5;"/>
                        <TextBlock Text="機能 B" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="説明テキスト" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Padding="16" Spacing="8">
                        <FontIcon FontSize="32" Glyph="&#xE734;"/>
                        <TextBlock Text="機能 C" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="説明テキスト" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
