<Window x:Class="ModernTrayApp.Core.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="450" Width="800"
        Background="White" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#F3F3F3" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <TextBlock Text="設定" FontSize="20" FontWeight="Bold" Margin="10,0,0,20"/>
                <ListBox x:Name="Sidebar" Background="Transparent" BorderThickness="0">
                    <ListBoxItem Content="一般" Padding="10"/>
                    <ListBoxItem Content="テーマ" Padding="10"/>
                </ListBox>
            </StackPanel>
        </Border>

        <Frame Grid.Column="1" x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="20"/>
    </Grid>
</Window>